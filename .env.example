# OAuth 2.0 bearer token for --upload api
# Generate at: https://www.openstreetmap.org/oauth2/applications
OSM_ACCESS_TOKEN=

# Optional: override Overpass API endpoint (e.g. local instance or alternate mirror)
# OVERPASS_URL = "https://overpass.kumi.systems/api/interpreter"

# Optional: override Nominatim endpoint (e.g. self-hosted instance)
# NOMINATIM_URL=https://nominatim.openstreetmap.org/search
